generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// 👇 Enum des rôles
enum Role {
  USER
  ADMIN
}

model User {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  password     String
  role         Role     @default(USER) // 👈 ajouter
  refreshToken String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}